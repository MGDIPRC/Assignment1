{
  "name": "assignment-1",
  "version": "1.0.0",
  "description": "This is a template repository for the first assignment in BVD 103 at McMaster Continuing Education.",
  "main": "index.js",
  "scripts": {
    "start-server": "npx tsx ./index.ts",
    "start:docker": "npx tsoa spec-and-routes && npx tsx ./index.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check",
    "typecheck": "npx tsoa spec-and-routes && tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest",
    "test:unit": "vitest run src",
    "test:api": "npx tsoa spec-and-routes && ./generate-openapi.sh && vitest run tests/api",
    "test:ci": "npx tsoa spec-and-routes && vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "14.0.0",
    "dotenv": "^17.2.3",
    "koa": "^2.16.3",
    "koa-bodyparser": "^4.4.1",
    "koa-qs": "^3.0.0",
    "koa-zod-router": "^2.3.0",
    "koa2-swagger-ui": "^5.12.0",
    "mongoose": "^9.1.5",
    "tsoa": "^7.0.0-alpha.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.30.0",
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.1",
    "@types/koa-qs": "^2.0.3",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.19.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "generator-function": "1.0.0"
  }
}